<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Ravi Online Service Dashboard</title>

<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,sans-serif;
}

body{
background:linear-gradient(135deg,#ff512f,#dd2476,#24c6dc,#5433ff);
background-size:400% 400%;
animation:bg 8s infinite alternate;
color:#fff;
}

@keyframes bg{
0%{background-position:left;}
100%{background-position:right;}
}

header{
background:#00000055;
padding:20px;
text-align:center;
font-size:28px;
font-weight:bold;
backdrop-filter:blur(8px);
}

.container{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(170px,1fr));
gap:20px;
padding:25px;
}

.card{
background:rgba(255,255,255,.15);
padding:25px;
border-radius:18px;
text-align:center;
backdrop-filter:blur(10px);
transition:.3s;
cursor:pointer;
}

.card:hover{
transform:scale(1.05);
background:rgba(255,255,255,.25);
}

.card h2{
font-size:20px;
margin-top:10px;
}

footer{
margin-top:30px;
padding:20px;
text-align:center;
background:#00000055;
}

.logout{
display:block;
width:220px;
margin:25px auto;
padding:15px;
text-align:center;
background:#ff0000;
color:#fff;
text-decoration:none;
border-radius:30px;
font-size:20px;
font-weight:bold;
}
</style>

</head>

<body>

<header>
🏠 Ravi Online Service Dashboard
</header>

<div class="container">

<div class="card">
<h1>👤</h1>
<h2>Profile</h2>
</div>

<div class="card">
<h1>💰</h1>
<h2>Wallet</h2>
</div>

<div class="card">
<h1>📱</h1>
<h2>Mobile Recharge</h2>
</div>

<div class="card">
<h1>⚡</h1>
<h2>Electricity Bill</h2>
</div>

<div class="card">
<h1>📺</h1>
<h2>DTH Recharge</h2>
</div>

<div class="card">
<h1>💳</h1>
<h2>Deposit</h2>
</div>

<div class="card">
<h1>📋</h1>
<h2>Recharge History</h2>
</div>

<div class="card">
<h1>☎️</h1>
<h2>Customer Support</h2>
</div>

</div>

<a href="index.html" class="logout">Logout</a>

<footer>
© 2026 Ravi Online Service | All Rights Reserved
</footer>

</body>
</html><a href="login.html" class="logout-btn" onclick="logoutUser()">
🚪 Logout
</a>